{
  "manifest_version": 3,
  "name": "Surge API Request Helper",
  "version": "1.0.0",
  "description": "Helper extension for Surge API Client to inject custom Cookie headers and bypass CORS.",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_icon": "logo.png"
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.unrealemo.space/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
